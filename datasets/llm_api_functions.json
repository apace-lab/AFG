    "_schema_notes": {
        "purpose": "Reference dataset of LLM SDK request-entry functions. STPA treats matching calls as black-box nodes in the PAG: taint flows from inputs to outputs by a summary rule (Item 2) instead of descending into the callee.",
        "usage": "For runtime use, copy entries into an example's taint_config.json under the \"taint\" array. fn_name must match the demangled Rust symbol; return_type and parameter_type are checked by PointerAnalysis::isTaintedFunction (PointerAnalysis.cpp:1892).",
        "match_rule": "demangled(callee) == fn_name AND returnType matches AND parameter_type.size() <= callee.arg_size()",
        "self_convention": "For methods, the receiver (&self / &mut self) is included as the first entry of parameter_type, matching the convention used in rust_input_functions.json for Tabby's chat/chat_stream."
    },

